# Editor options
backup=yes
terminal=xfce4-terminal --geometry 100x30+2160+740 --working-directory=
filemanager=nemo --geometry 777x655+2300+40
previous=yes
browser=firefox
theme=twilight
scope=/path...
# AI stuff
openai=GPTKEY
model=gpt-5-nano
ailog=yes
aiconfirm=yes
role=You are a helpful coding and technology assistant
# User applications
run1=firefox https://ttkbootstrap.readthedocs.io/en/latest
run2=xxx
run3=xxx
run4=python3 {f}
nam1=ttkbootstrap
nam2=xxx
nam3=xxx
nam4=python3
# COLOR THEMES:
# monokai | cobalt | vibrant_ink | clouds_midnight | solarized_dark
# tomorrow_night_eighties | twilight | kr_theme | Terminal
# solarized_light | textmate | tomorrow_night
